# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the browser. Only use in server-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Create a token at https://account.mapbox.com/access-tokens/
# Scope: styles:read, tiles:read
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# ─── Web Push (optional — for push notifications) ────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
